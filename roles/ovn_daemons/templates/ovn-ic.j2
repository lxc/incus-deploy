{% set servers = lookup('template', 'ovn-ic.servers.j2') | from_yaml -%}
# Managed by Ansible, do not modify.

# This is a POSIX shell fragment                -*- sh -*-

# OVN_CTL_OPTS: Extra options to pass to ovs-ctl.  This is, for example,
# a suitable place to specify --ovn-northd-wrapper=valgrind.

OVN_CTL_OPTS="\
    --db-ic-nb-create-insecure-remote=no \
    --db-ic-sb-create-insecure-remote=no \
    --db-ic-nb-addr=[{{ ovn_daemons_ip_address }}] \
    --db-ic-sb-addr=[{{ ovn_daemons_ip_address }}] \
    --db-ic-nb-cluster-local-addr=[{{ ovn_daemons_ip_address }}] \
    --db-ic-sb-cluster-local-addr=[{{ ovn_daemons_ip_address }}] \
    --ovn-ic-ssl-key=/etc/ovn/{{ ovn_daemons_name }}.server.key \
    --ovn-ic-ssl-cert=/etc/ovn/{{ ovn_daemons_name }}.server.crt \
    --ovn-ic-ssl-ca-cert=/etc/ovn/{{ ovn_daemons_name }}.ca.crt \
    --ovn-northd-nb-db={{ ovn_daemons_central_northbound }} \
    --ovn-northd-sb-db={{ ovn_daemons_central_southbound }} \
    --ovn-ic-nb-db={{ ovn_daemons_ic_northbound }} \
    --ovn-ic-sb-db={{ ovn_daemons_ic_southbound }}{% if ovn_daemons_ip_address != servers[0] %} \
    --db-ic-nb-cluster-remote-addr=[{{ servers[0] }}]
    --db-ic-sb-cluster-remote-addr=[{{ servers[0] }}]{% endif %}"
